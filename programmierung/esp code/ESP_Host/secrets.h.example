// secrets.h.example — Template für WiFi-Zugangsdaten des ESP_Host
//
// ANLEITUNG:
//   1. Diese Datei kopieren und als "secrets.h" im selben Ordner speichern.
//   2. Die Platzhalter durch eure echten Zugangsdaten ersetzen.
//   3. secrets.h ist in .gitignore eingetragen und wird NICHT auf GitHub hochgeladen.
//
// INSTRUCTIONS (English):
//   1. Copy this file and save it as "secrets.h" in the same folder.
//   2. Replace the placeholders with your actual credentials.
//   3. secrets.h is listed in .gitignore and will NOT be uploaded to GitHub.

#pragma once

// WiFi Access Point name (SSID) that the Raspberry Pi connects to
#define AP_SSID     "DEIN_NETZWERKNAME"

// WiFi Access Point password — choose something strong! (min. 8 characters)
#define AP_PASSWORD "DEIN_SICHERES_PASSWORT"
